{
  "name": "visohelp",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo do VisoHelp",
  "scripts": {
    "dev:web": "npm run dev --prefix apps/web",
    "dev:desktop": "npm run dev --prefix apps/desktop",
    "dev:mobile": "npm run start --prefix apps/mobile",
    "dev:backend": "dotnet run --project apps/backend/VisoHelp.Api.csproj",
    "dev:agent": "dotnet run --project apps/agent/VisoHelp.Agent.csproj",
    "build:web": "npm run build --prefix apps/web",
    "build:desktop": "npm run build --prefix apps/desktop"
  }
}
