# Rede Docker onde ja esta o container Postgres (mesma VPS).
# Ex.: bridge, postgres_default, ou nome listado em: docker network ls
EXTERNAL_DOCKER_NETWORK=postgres_default

# Connection string Npgsql. Host = nome do servico/container Postgres NA MESMA REDE.
# Use aspas simples se for fazer "source .env" no bash (o ';' parte o valor sem aspas).
# Ex.: 'Host=postgres;Port=5432;Database=visohelp;Username=visohelp;Password=...'
POSTGRES_CONNECTION_STRING=

# Primeiro login (analista master). Sem isto, a API nao cria utilizador e o login devolve 401.
# Depois de definir, reinicie o container da API (docker compose up -d api).
MASTER_ANALYST_EMAIL=
MASTER_ANALYST_PASSWORD=
# MASTER_ANALYST_FORCE_PASSWORD_RESET=false
# MASTER_ANALYST_DISPLAY_NAME=
# MASTER_ANALYST_DEFAULT_TEAM_NAME=Administradores

# JWT (minimo ~32 caracteres em producao)
JWT_KEY=
JWT_ISSUER=VisoHelp
JWT_AUDIENCE=VisoHelp.Web

# Front chama a API (URL publica HTTPS)
NEXT_PUBLIC_API_URL=https://api.dizparo.com.br

# CORS na API (origem do Next em producao)
PUBLIC_APP_ORIGIN=https://app.dizparo.com.br

# Portas no host (Nginx/Caddy faz proxy para estas)
API_HOST_PORT=5212
WEB_HOST_PORT=3000
